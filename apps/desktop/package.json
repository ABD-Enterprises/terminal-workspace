{
  "name": "desktop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "backend": "node ./server/backend.mjs",
    "dev:full": "concurrently -k -n backend,ui \"pnpm backend\" \"vite --host 127.0.0.1 --port 5173\"",
    "build": "tsc -b && vite build",
