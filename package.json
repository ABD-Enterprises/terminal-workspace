{
  "name": "terminal-workspace",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "pnpm --filter desktop dev:full",
    "build": "pnpm --filter desktop build",
    "native:icons": "bash ./scripts/generate-tauri-icons.sh",
