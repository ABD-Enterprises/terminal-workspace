{
  "name": "terminal-workspace",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "setup": "bash ./bootstrap.sh",
    "dev": "node ./scripts/pnpmw.mjs --filter desktop dev:full",
    "dev:ui": "node ./scripts/pnpmw.mjs --filter desktop exec vite --host 127.0.0.1 --port 5173",
    "build": "npm --prefix ./apps/desktop run build",
    "typecheck": "npm --prefix ./apps/desktop run typecheck",
    "native:icons": "bash ./scripts/generate-tauri-icons.sh",
    "native:check": "bash ./scripts/native-check.sh",
    "native:bundle": "MACOS_SIGN_MODE=require bash ./scripts/native-bundle.sh",
    "native:bundle:preview": "MACOS_SIGN_MODE=skip bash ./scripts/native-bundle.sh",
    "native:release:check": "bash ./scripts/native-release-check.sh",
    "native:notarize": "bash ./scripts/native-notarize.sh",
    "native:notary:auth:test": "bash ./scripts/native-notary-auth-test.sh",
    "native:promote": "bash ./scripts/native-promote.sh",
    "native:publish": "bash ./scripts/native-publish-release.sh",
    "native:publish:dry-run": "RELEASE_DRY_RUN=1 bash ./scripts/native-publish-release.sh",
    "release:secrets:audit": "node ./scripts/github-release-secrets.mjs audit",
    "release:secrets:validate-env": "node ./scripts/github-release-secrets.mjs validate-env",
    "release:secrets:apply-env": "node ./scripts/github-release-secrets.mjs apply-env",
    "release:secrets:apply-env:dry-run": "node ./scripts/github-release-secrets.mjs apply-env --dry-run",
    "native:fixtures": "bash ./scripts/native-transport-test.sh",
    "native:key": "bash ./scripts/native-key-tooling-test.sh",
    "native:trust": "bash ./scripts/native-trust-tooling-test.sh",
    "native:build": "bash ./scripts/native-build.sh",
    "validate:guardrails": "node ./tools/validators/enforce-runtime-guardrails.js --repo . --config ai.config.json",
    "lint": "eslint .",
    "test": "vitest run --config vitest.config.ts",
    "e2e": "playwright test --config playwright.config.ts",
    "setup:browsers": "playwright install chromium",
    "validate": "bash ./scripts/validate.sh"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.0",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.1.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "typescript-eslint": "^8.57.2",
    "vitest": "^3.2.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "cpu-features",
      "esbuild",
      "ssh2"
    ]
  }
}
