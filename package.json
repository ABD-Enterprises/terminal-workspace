    "native:build": "bash ./scripts/native-build.sh",
    "lint": "eslint .",
    "test": "vitest run",
    "e2e": "playwright test"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.1.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "typescript-eslint": "^8.57.2"
  }
}
