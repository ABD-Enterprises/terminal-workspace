{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Terminal Workspace",
  "version": "0.1.0",
  "identifier": "com.abdenterprises.terminalworkspace",
  "build": {
    "frontendDist": "../apps/desktop/dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Terminal Workspace",
        "width": 1400,
        "height": 900,
        "dragDropEnabled": false,
        "transparent": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "windowEffects": {
          "effects": ["sidebar"],
          "state": "followsWindowActiveState"
        }
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src 'self' ipc: tauri:; object-src 'none'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
    }
  },
  "bundle": {
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "sql": {
      "preload": ["sqlite:termsnip.db"]
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEI5RkNDNzA0OTAxQzA5N0EKUldSNkNSeVFCTWY4dWQxL0x5MkFtYy9tcUU2QnB6QWprUU9nRDdkRHFjdnRXeGZFL05UUHBCMjAK",
      "endpoints": [
        "https://github.com/ABD-Enterprises/terminal-workspace/releases/latest/download/latest.json"
      ]
    }
  }
}
