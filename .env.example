# Shared local ports
TERMSNIP_BACKEND_PORT=8790
TERMSNIP_BACKEND_BASE_URL=http://127.0.0.1:8790
TERMSNIP_UI_PORT=5173

# Per-launch authentication for the Node backend. Leave both blank in normal
# dev — the backend will auto-generate a 32-byte hex token on startup, write
# it to ${TMPDIR}/termsnip-backend.<port>.token (mode 0600), and the Tauri
# shell will pick it up from the same file. Set TERMSNIP_BACKEND_TOKEN
# explicitly when you want both processes to agree on a token before they
# start (e.g. CI / containerised dev). Set TERMSNIP_ALLOWED_ORIGINS as a
# comma-separated list to extend the browser-origin allowlist beyond the
# defaults (vite dev + Tauri internals). See
# docs/parity-and-hardening-review.md §3.S-4 / §3.S-8.
TERMSNIP_BACKEND_TOKEN=
TERMSNIP_ALLOWED_ORIGINS=

# Release defaults
MACOS_RELEASE_CHANNEL=stable
RELEASE_TAG=v0.1.0

# Developer ID signing
MACOS_SIGN_IDENTITY=Developer ID Application: Example, Inc. (TEAMID)

# Preferred notarization path: App Store Connect API key
MACOS_NOTARY_KEY_ID=
MACOS_NOTARY_ISSUER=
MACOS_NOTARY_KEY_BASE64=

# Fallback notarization path: Apple ID app-specific password
MACOS_NOTARY_APPLE_ID=
MACOS_NOTARY_APP_PASSWORD=
MACOS_NOTARY_TEAM_ID=

# Local-machine fallback only
MACOS_NOTARY_PROFILE=

# CI certificate secrets are expected as environment variables or GitHub Secrets:
# MACOS_CERTIFICATE_P12_BASE64
# MACOS_CERTIFICATE_PASSWORD
# MACOS_KEYCHAIN_PASSWORD
