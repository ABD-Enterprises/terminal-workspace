.DS_Store
.env
node_modules/
.pnpm-store/
apps/desktop/dist/
src-tauri/target/
playwright-report/
test-results/
artifacts/e2e/
artifacts/validation/
# Build output from native:bundle / native:notarize. Manifests, signed
# archives, codesign + spctl + stapler logs all land here. Recreated by
# every build; should not be tracked.
artifacts/release/

*.tsbuildinfo

# Per-session Claude Code editor state (scheduled_tasks.lock holds the
# active session id + pid). Local to the developer; never part of the
# repo.
.claude/

# Pipeline state and retained evidence files must not be gitignored — they are required by the AI validator
.worktrees/
